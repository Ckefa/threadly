package handlers

import (
	"fmt"
	"net/http"
	"strings"
	"time"

	"threadly/internal/db"
	"threadly/internal/models"
	"threadly/internal/services"

	"github.com/gin-gonic/gin"
)

func ShowCustomerLogin(c *gin.Context) {
	c.HTML(200, "customer_login.html", gin.H{
		"Title": "Customer Login - Threadly",
	})
}

func SendCustomerOTP(c *gin.Context) {
	email := c.PostForm("email")
	if email == "" {
		c.HTML(400, "customer_login.html", gin.H{
			"Title": "Customer Login - Threadly",
			"Error": "Email is required",
		})
		return
	}

	otp, err := services.SendCustomerOTP(email)
	if err != nil {
		c.HTML(400, "customer_login.html", gin.H{
			"Title": "Customer Login - Threadly",
			"Error": "Customer not found",
		})
		return
	}

	c.HTML(200, "customer_otp.html", gin.H{
		"Title": "Enter OTP - Threadly",
		"Email": email,
		"OTP":   otp, // For testing only
	})
}

func VerifyCustomerOTP(c *gin.Context) {
	email := c.PostForm("email")
	otpCode := c.PostForm("otp")

	if email == "" || otpCode == "" {
		c.HTML(400, "customer_otp.html", gin.H{
			"Title": "Enter OTP - Threadly",
			"Email": email,
			"Error": "Email and OTP are required",
		})
		return
	}

	customerAuth, err := services.VerifyCustomerOTP(email, otpCode)
	if err != nil {
		c.HTML(400, "customer_otp.html", gin.H{
			"Title": "Enter OTP - Threadly",
			"Email": email,
			"Error": "Invalid or expired OTP",
		})
		return
	}

	// Mark as verified
	customerAuth.IsVerified = true
	customerAuth.OTPCode = "" // Clear OTP after verification
	db.DB.Save(&customerAuth)

	// Update customer online status
	now := time.Now()
	db.DB.Model(&models.Client{}).Where("id = ?", customerAuth.ClientID).Updates(map[string]interface{}{
		"is_online":    true,
		"last_seen_at": &now,
	})

	// Generate JWT token
	token, err := services.GenerateCustomerToken(customerAuth)
	if err != nil {
		c.HTML(500, "customer_otp.html", gin.H{
			"Title": "Enter OTP - Threadly",
			"Email": email,
			"Error": "Failed to generate token",
		})
		return
	}

	// Set cookie and redirect
	c.SetCookie("customer_token", token, 86400, "/", "", false, true)
	c.Redirect(http.StatusFound, "/customer/dashboard")
}

func CustomerDashboard(c *gin.Context) {
	// Get customer info from token
	token := c.GetHeader("Authorization")
	if token == "" {
		token, _ = c.Cookie("customer_token")
	}

	if token == "" {
		c.Redirect(http.StatusFound, "/customer/login")
		return
	}

	// Remove "Bearer " prefix if present
	if strings.HasPrefix(token, "Bearer ") {
		token = strings.TrimPrefix(token, "Bearer ")
	}

	claims, err := services.ValidateToken(token)
	if err != nil || claims.Subject != "customer" {
		c.Redirect(http.StatusFound, "/customer/login")
		return
	}

	// Get customer's businesses (the businesses they have conversations with)
	var businesses []struct {
		ID    uint   `json:"id"`
		Name  string `json:"name"`
		Email string `json:"email"`
		Type  string `json:"business_type"`
	}

	err = db.DB.Raw(`
		SELECT DISTINCT u.id, u.first_name || ' ' || u.last_name as name, u.email, u.business_type
		FROM users u
		JOIN clients c ON u.id = c.user_id
		JOIN conversations conv ON c.id = conv.client_id
		WHERE c.email = ?
	`, claims.Email).Scan(&businesses).Error

	if err != nil {
		c.HTML(500, "customer_dashboard.html", gin.H{
			"Title": "Customer Dashboard - Threadly",
			"Error": "Failed to load businesses",
		})
		return
	}

	c.HTML(200, "customer_dashboard.html", gin.H{
		"Title":      "Customer Dashboard - Threadly",
		"Email":      claims.Email,
		"Businesses": businesses,
	})
}

type MessageObj struct {
	ID        uint        `json:"id"`
	MsgType   string      `json:"msgtype"` // "message", "order", "booking"
	Value     string      `json:"value"`   // string content for normal messages, empty for orders/bookings
	Data      interface{} `json:"data"`    // order object or booking object as JSON, null for normal messages
	Sender    string      `json:"sender"`
	CreatedAt time.Time   `json:"created_at"`
}

func GetCustomerMessages(c *gin.Context) {
	customerEmail := "test@example.com" // Use same customer as booking creation
	businessID := c.Param("business_id")

	// Get the customer's client record for this business
	var client models.Client
	err := db.DB.Raw(`
		SELECT c.* FROM clients c
		JOIN users u ON c.user_id = u.id
		WHERE c.email = ? AND u.id = ?
	`, customerEmail, businessID).First(&client).Error

	if err != nil {
		c.String(404, "Conversation not found")
		return
	}

	// Get conversation
	var conversation models.Conversation
	if err := db.DB.Where("client_id = ?", client.ID).First(&conversation).Error; err != nil {
		c.String(404, "Conversation not found")
		return
	}

	// Get messages
	var messages []models.Message
	if err := db.DB.Where("conversation_id = ?", conversation.ID).Order("created_at ASC").Find(&messages).Error; err != nil {
		c.String(500, "Failed to load messages")
		return
	}

	// Convert messages to MessageObj
	var messageObjs []MessageObj
	for _, msg := range messages {
		messageObj := MessageObj{
			ID:        msg.ID,
			MsgType:   msg.Type,
			Value:     msg.Content,
			Data:      nil,
			Sender:    msg.Sender,
			CreatedAt: msg.CreatedAt,
		}

		// Debug logging
		fmt.Printf("DEBUG: Message ID=%d, MsgType='%s', Value='%s'\n", messageObj.ID, messageObj.MsgType, messageObj.Value)

		messageObjs = append(messageObjs, messageObj)
	}

	// Fetch orders directly from database and transform into MessageObj
	var orders []models.Order
	if err := db.DB.Where("customer_id = ? AND user_id = ?", client.ID, businessID).Order("created_at ASC").Find(&orders).Error; err != nil {
		fmt.Printf("DEBUG: Error fetching orders: %v\n", err)
	} else {
		fmt.Printf("DEBUG: Found %d orders\n", len(orders))
		for _, order := range orders {
			// Get order items to get product details
			var orderItems []models.OrderItem
			db.DB.Where("order_id = ?", order.ID).Find(&orderItems)

			var productNames []string
			for _, item := range orderItems {
				var product models.Product
				db.DB.First(&product, item.ProductID)
				productNames = append(productNames, product.Name)
			}

			// Create order object with all necessary data
			orderData := map[string]interface{}{
				"id":            order.ID,
				"order_number":  order.OrderNumber,
				"status":        order.Status,
				"total_amount":  order.TotalAmount,
				"notes":         order.Notes,
				"created_at":    order.CreatedAt,
				"product_names": productNames,
			}

			orderMessageObj := MessageObj{
				ID:        order.ID + 10000, // Offset to avoid ID conflicts with messages
				MsgType:   "order",
				Value:     "", // Empty for orders
				Data:      orderData,
				Sender:    "client",
				CreatedAt: order.CreatedAt,
			}

			messageObjs = append(messageObjs, orderMessageObj)
			fmt.Printf("DEBUG: Added Order ID=%d, MsgType='%s', Data='%+v'\n", orderMessageObj.ID, orderMessageObj.MsgType, orderData)
		}
	}

	// Fetch bookings directly from database and transform into MessageObj
	fmt.Printf("DEBUG: About to fetch bookings for client_id=%d, user_id=%s (customer email: %s)\n", client.ID, businessID, client.Email)
	var bookings []models.Booking
	fmt.Printf("DEBUG: Querying bookings for client_id=%d, user_id=%s\n", client.ID, businessID)
	if err := db.DB.Where("customer_id = ? AND user_id = ?", client.ID, businessID).Order("created_at ASC").Find(&bookings).Error; err != nil {
		fmt.Printf("DEBUG: Error fetching bookings: %v\n", err)
	} else {
		fmt.Printf("DEBUG: Found %d bookings\n", len(bookings))

		// Also check if there are any bookings in the database at all
		var totalBookings []models.Booking
		db.DB.Find(&totalBookings)
		fmt.Printf("DEBUG: Total bookings in database: %d\n", len(totalBookings))

		// Check if there are any bookings for this customer (regardless of business)
		var customerBookings []models.Booking
		db.DB.Where("customer_id = ?", client.ID).Find(&customerBookings)
		fmt.Printf("DEBUG: Bookings for customer_id=%d: %d\n", client.ID, len(customerBookings))
		for _, booking := range bookings {
			// Get booking items to get service details
			var bookingItems []models.BookingItem
			db.DB.Where("booking_id = ?", booking.ID).Find(&bookingItems)

			var serviceNames []string
			for _, item := range bookingItems {
				var service models.Service
				db.DB.First(&service, item.ServiceID)
				serviceNames = append(serviceNames, service.Name)
			}

			// Create booking object with all necessary data
			bookingData := map[string]interface{}{
				"id":             booking.ID,
				"booking_number": booking.BookingNumber,
				"status":         booking.Status,
				"scheduled_date": booking.ScheduledDate,
				"duration":       booking.Duration,
				"total_amount":   booking.TotalAmount,
				"notes":          booking.Notes,
				"created_at":     booking.CreatedAt,
				"service_names":  serviceNames,
			}

			bookingMessageObj := MessageObj{
				ID:        booking.ID + 20000, // Offset to avoid ID conflicts with messages and orders
				MsgType:   "booking",
				Value:     "", // Empty for bookings
				Data:      bookingData,
				Sender:    "client",
				CreatedAt: booking.CreatedAt,
			}

			messageObjs = append(messageObjs, bookingMessageObj)
			fmt.Printf("DEBUG: Added Booking ID=%d, MsgType='%s', Data='%+v'\n", bookingMessageObj.ID, bookingMessageObj.MsgType, bookingData)
		}
	}

	// Sort all messageObjs by CreatedAt
	for i := 0; i < len(messageObjs); i++ {
		for j := i + 1; j < len(messageObjs); j++ {
			if messageObjs[i].CreatedAt.After(messageObjs[j].CreatedAt) {
				messageObjs[i], messageObjs[j] = messageObjs[j], messageObjs[i]
			}
		}
	}
	fmt.Printf("======%f", messages)

	fmt.Printf("DEBUG: Total messages=%d, orders=%d, bookings=%d, MessageObjs=%d\n", len(messages), len(orders), len(bookings), len(messageObjs))

	// Get business info
	var business struct {
		ID   uint   `json:"id"`
		Name string `json:"name"`
		Type string `json:"business_type"`
	}
	db.DB.Raw("SELECT id, first_name || ' ' || last_name as name, business_type FROM users WHERE id = ?", businessID).First(&business)

	c.HTML(200, "customer_chat.html", gin.H{
		"Business":    business,
		"Client":      client,
		"Messages":    messages,
		"MessageObjs": messageObjs,
	})
}

func CreateCustomerMessage(c *gin.Context) {
	customerEmail := c.GetString("customer_email")
	businessID := c.Param("business_id")

	// Get the customer's client record for this business
	var client models.Client
	err := db.DB.Raw(`
		SELECT c.* FROM clients c
		JOIN users u ON c.user_id = u.id
		WHERE c.email = ? AND u.id = ?
	`, customerEmail, businessID).First(&client).Error

	if err != nil {
		c.String(404, "Conversation not found")
		return
	}

	// Get conversation
	var conversation models.Conversation
	if err := db.DB.Where("client_id = ?", client.ID).First(&conversation).Error; err != nil {
		c.String(404, "Conversation not found")
		return
	}

	content := c.PostForm("content")
	sender := "client" // Customer messages are always from client

	message := models.Message{
		ConversationID: conversation.ID,
		Content:        content,
		Type:           "message",
		Sender:         sender,
	}

	if err := db.DB.Create(&message).Error; err != nil {
		c.String(500, "Failed to create message")
		return
	}

	// Return message partial
	c.HTML(200, "customer_message_partial.html", gin.H{
		"Message": message,
	})
}

func CustomerMiddleware() gin.HandlerFunc {
	return func(c *gin.Context) {
		token := c.GetHeader("Authorization")
		if token == "" {
			token, _ = c.Cookie("customer_token")
		}

		if token == "" {
			c.Redirect(http.StatusFound, "/customer/login")
			c.Abort()
			return
		}

		// Remove "Bearer " prefix if present
		token = strings.TrimPrefix(token, "Bearer ")

		claims, err := services.ValidateToken(token)
		if err != nil || claims.Subject != "customer" {
			c.Redirect(http.StatusFound, "/customer/login")
			c.Abort()
			return
		}

		c.Set("customer_id", claims.UserID)
		c.Set("customer_email", claims.Email)
		c.Next()
	}
}

func CustomerHeartbeat(c *gin.Context) {
	// Get customer info from token
	token := c.GetHeader("Authorization")
	if token == "" {
		token, _ = c.Cookie("customer_token")
	}

	if token == "" {
		c.JSON(401, gin.H{"error": "No token"})
		return
	}

	token = strings.TrimPrefix(token, "Bearer ")
	claims, err := services.ValidateToken(token)
	if err != nil || claims.Subject != "customer" {
		c.JSON(401, gin.H{"error": "Invalid token"})
		return
	}

	// Update customer online status
	now := time.Now()
	db.DB.Model(&models.Client{}).Where("id = ?", claims.UserID).Updates(map[string]interface{}{
		"is_online":    true,
		"last_seen_at": &now,
	})

	c.JSON(200, gin.H{"status": "ok", "timestamp": now})
}

func CustomerLogout(c *gin.Context) {
	// Get customer info from token
	token, _ := c.Cookie("customer_token")
	if token != "" {
		token = strings.TrimPrefix(token, "Bearer ")
		claims, err := services.ValidateToken(token)
		if err == nil && claims.Subject == "customer" {
			// Update customer offline status
			db.DB.Model(&models.Client{}).Where("id = ?", claims.UserID).Update("is_online", false)
		}
	}

	// Clear cookie and redirect
	c.SetCookie("customer_token", "", -1, "/", "", false, true)
	c.Redirect(http.StatusFound, "/customer/login")
}
<!-- Main Chat Container -->
<div class="flex-1 flex flex-col bg-gray-50 h-screen max-h-screen">

<!-- Chat Header -->
<div class="bg-white border-b border-gray-200 p-4 flex items-center justify-between flex-shrink-0">
    <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-teal-100 rounded-full flex items-center justify-center">
            <i class="fas fa-store text-teal-600"></i>
        </div>
        <div>
            <h2 class="font-semibold text-gray-900">{{.Business.Name}}</h2>
            <p class="text-sm text-gray-500">{{.Business.Type}}</p>
        </div>
    </div>
    <div class="flex items-center space-x-2">
        <span class="inline-block w-2 h-2 bg-green-500 rounded-full"></span>
        <span class="text-sm text-gray-500">Online</span>
    </div>
</div>

<!-- Messages Area -->
<div class="flex-1 overflow-y-auto p-4 space-y-4 min-h-0" id="messages-container">
    {{range .MessageObjs}}
    
    <!-- DEBUG: Processing MsgType = {{.MsgType}} -->
    {{if eq .MsgType "message"}}
    <!-- MESSAGE CONDITION MATCHED - MsgType: {{.MsgType}} - Value: {{.Value}} -->
    <div class="flex justify-end">
        <div class="max-w-xs lg:max-w-md">
            <div class="bg-teal-600 text-white rounded-lg px-4 py-2">
                <p class="text-sm">{{.Value}}</p>
            </div>
            <div class="flex items-center justify-between mt-1">
                <p class="text-xs text-gray-500">{{.CreatedAt.Format "3:04 PM"}}</p>
            </div>
        </div>
    </div>
    {{else if eq .MsgType "order"}}
    <!-- Order Card - MsgType: {{.MsgType}} - Data: {{.Data}} -->
    <div class="flex justify-end">
        <div class="max-w-xs lg:max-w-md w-full">
            <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-3" data-message-id="{{.ID}}" data-order-data="{{.Data}}">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center space-x-2">
                        <span class="font-semibold text-blue-800 text-sm order-id">[{{if .Data}}{{.Data.id}}{{else}}N/A{{end}}]</span>
                        <span class="text-gray-700 text-sm product-name">{{if .Data}}{{if .Data.product_names}}{{index .Data.product_names 0}}{{else}}Unknown Product{{end}}{{else}}Unknown Product{{end}}</span>
                        <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded order-status">{{if .Data}}{{.Data.status}}{{else}}Unknown{{end}}</span>
                    </div>
                    <button data-message-id="{{.ID}}" onclick="editOrderMessage(this.getAttribute('data-message-id'))" class="text-blue-600 hover:text-blue-800 text-xs" title="Edit Order">
                        <i class="fas fa-edit"></i>
                    </button>
                </div>
                <div class="order-details text-sm text-gray-700">
                    <p class="text-sm">Order #{{if .Data}}{{if .Data.order_number}}{{.Data.order_number}}{{else}}Unknown{{end}}{{else}}Unknown{{end}} - ${{if .Data}}{{if .Data.total_amount}}{{printf "%.2f" .Data.total_amount}}{{else}}0.00{{end}}{{else}}0.00{{end}}</p>
                    {{if .Data}}{{if .Data.notes}}<p class="text-xs text-gray-600 mt-1">Notes: {{.Data.notes}}</p>{{end}}{{end}}
                </div>
                <div class="flex items-center justify-between mt-2">
                    <p class="text-xs text-gray-500">{{.CreatedAt.Format "3:04 PM"}}</p>
                </div>
            </div>
        </div>
    </div>
    {{else if eq .MsgType "booking"}}
    <!-- Booking Card - MsgType: {{.MsgType}} - REACHED BOOKING TEMPLATE -->
    <div class="flex justify-end">
        <div class="max-w-xs lg:max-w-md w-full">
            <div class="bg-purple-50 border border-purple-200 rounded-lg px-4 py-3" data-message-id="{{.ID}}" data-booking-data="{{.Data}}">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center space-x-2">
                        <i class="fas fa-calendar-plus text-purple-600"></i>
                        <span class="font-semibold text-purple-800 text-sm">Booking</span>
                        <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded booking-status">{{if .Data}}{{.Data.status}}{{else}}Unknown{{end}}</span>
                    </div>
                    <button data-message-id="{{.ID}}" onclick="editBookingMessage(this.getAttribute('data-message-id'))" class="text-purple-600 hover:text-purple-800 text-xs" title="Edit Booking">
                        <i class="fas fa-edit"></i>
                    </button>
                </div>
                <div class="booking-details text-sm text-gray-700">
                    <p class="text-sm">{{if .Data.service_names}}{{index .Data.service_names 0}}{{else}}Unknown Service{{end}}</p>
                    <p class="text-xs text-gray-600">{{if .Data.scheduled_date}}{{.Data.scheduled_date.Format "Jan 2, 2006 3:04 PM"}}{{else}}Unknown Date{{end}}</p>
                    {{if .Data.notes}}<p class="text-xs text-gray-600 mt-1">Notes: {{.Data.notes}}</p>{{end}}
                </div>
                <div class="flex items-center justify-between mt-2">
                    <p class="text-xs text-gray-500">{{.CreatedAt.Format "3:04 PM"}}</p>
                </div>
            </div>
        </div>
    </div>
    {{else}}
    <div class="text-center text-gray-500 py-8">
        <i class="fas fa-inbox text-4xl mb-2"></i>
        <p>No messages yet. Start the conversation!</p>
    </div>
    {{end}}
    {{end}}
</div>

<!-- Message Input -->
<div class="bg-white border-t border-gray-200 p-4" style="position: sticky; bottom: 0;">
    <!-- Client Quick Actions -->
    <div class="flex space-x-2 mb-3">
        <button onclick="openClientOrderModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-2 rounded-lg text-sm flex items-center space-x-1">
            <i class="fas fa-shopping-cart"></i>
            <span>Place Order</span>
        </button>
        <button onclick="openClientBookingModal()" class="bg-purple-600 hover:bg-purple-700 text-white px-3 py-2 rounded-lg text-sm flex items-center space-x-1">
            <i class="fas fa-calendar-plus"></i>
            <span>Request Booking</span>
        </button>
    </div>
    
    <form id="message-form" hx-post="/customer/businesses/{{.Business.ID}}/messages" 
          hx-target="#messages-container" hx-swap="beforeend"
          hx-on::after-request="this.reset()">
        <div class="flex space-x-3">
            <input type="text" name="content" placeholder="Type a message..." 
                   class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                   required>
            <input type="hidden" name="sender" value="client">
            <button type="submit" class="bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700">
                <i class="fas fa-paper-plane"></i> Send
            </button>
        </div>
    </form>
</div>

<script>
    let heartbeatInterval = null;
    const businessId = parseInt('{{.Business.ID}}');

    document.addEventListener('DOMContentLoaded', function() {
        // Start heartbeat to keep customer online
        startHeartbeat();
    });

    function startHeartbeat() {
        // Send heartbeat every 30 seconds
        heartbeatInterval = setInterval(function() {
            fetch('/customer/heartbeat', {
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + getCookie('customer_token')
                }
            }).catch(console.error);
        }, 30000);
    }

    function getCookie(name) {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) return parts.pop().split(';').shift();
    }

    function stopHeartbeat() {
        if (heartbeatInterval) {
            clearInterval(heartbeatInterval);
            heartbeatInterval = null;
        }
    }

    // Clean up heartbeat when page is unloaded
    window.addEventListener('beforeunload', stopHeartbeat);

    // Client Order and Booking Functions
    function openClientOrderModal() {
        loadClientProducts();
        document.getElementById('clientOrderModal').classList.remove('hidden');
    }

    function hideClientOrderModal() {
        console.log('hideClientOrderModal called');
        const modal = document.getElementById('clientOrderModal');
        const form = document.getElementById('clientOrderForm');
        console.log('Modal element:', modal);
        console.log('Form element:', form);
        
        if (modal) {
            modal.classList.add('hidden');
            console.log('Modal hidden');
        } else {
            console.error('Modal not found!');
        }
        
        if (form) {
            form.reset();
            console.log('Form reset');
        } else {
            console.error('Form not found!');
        }
    }

    function openClientBookingModal() {
        loadClientServices();
        document.getElementById('clientBookingModal').classList.remove('hidden');
    }

    function hideClientBookingModal() {
        document.getElementById('clientBookingModal').classList.add('hidden');
        document.getElementById('clientBookingForm').reset();
    }

    async function loadClientProducts() {
        try {
            const response = await fetch(`/customer/businesses/${businessId}/products`);
            const products = await response.json();
            const select = document.getElementById('clientOrderProduct');
            
            select.innerHTML = '<option value="">Choose a product...</option>';
            products.forEach(product => {
                const option = document.createElement('option');
                option.value = product.id;
                option.textContent = `${product.name} - $${product.price}`;
                select.appendChild(option);
            });
        } catch (error) {
            console.error('Error loading products:', error);
        }
    }

    async function loadClientServices() {
        try {
            console.log('Loading services for business:', businessId);
            const response = await fetch(`/customer/businesses/${businessId}/services`);
            console.log('Services response status:', response.status);
            
            if (!response.ok) {
                if (response.status === 401) {
                    console.error('Authentication failed for services');
                    showNotification('Please login to access services', 'error');
                    return;
                }
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            
            const services = await response.json();
            console.log('Services loaded:', services);
            const select = document.getElementById('clientBookingService');
            
            select.innerHTML = '<option value="">Choose a service...</option>';
            if (services.length === 0) {
                select.innerHTML = '<option value="">No services available</option>';
                showNotification('No services available for booking', 'warning');
                return;
            }
            
            services.forEach(service => {
                const option = document.createElement('option');
                option.value = service.id;
                const price = service.min_price || service.max_price || 'Price not set';
                option.textContent = `${service.name} - $${price}`;
                select.appendChild(option);
            });
        } catch (error) {
            console.error('Error loading services:', error);
            showNotification('Failed to load services', 'error');
        }
    }

    // Handle client order form submission
    function submitOrderForm() {
        console.log('submitOrderForm called');
        
        const productSelect = document.getElementById('clientOrderProduct');
        const quantityInput = document.getElementById('clientOrderQuantity');
        const addressInput = document.getElementById('clientOrderAddress');
        const notesInput = document.getElementById('clientOrderNotes');
        
        console.log('Form elements:', {
            productSelect: productSelect?.value,
            quantityInput: quantityInput?.value,
            addressInput: addressInput?.value,
            notesInput: notesInput?.value,
            businessId: businessId
        });
        
        // Validate form
        if (!productSelect.value) {
            console.log('Validation failed: no product selected');
            showNotification('Please select a product', 'error');
            return;
        }
        if (!quantityInput.value || quantityInput.value < 1) {
            console.log('Validation failed: invalid quantity');
            showNotification('Please enter a valid quantity', 'error');
            return;
        }
        
        const orderData = {
            product_id: parseInt(productSelect.value),
            quantity: parseInt(quantityInput.value),
            delivery_address: addressInput.value,
            notes: notesInput.value,
            business_id: parseInt(businessId)
        };

        console.log('Sending order data:', orderData);
        
        console.log('Sending order without authentication for testing');

        fetch('/customer/orders', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(orderData)
        })
        .then(response => {
            console.log('Response status:', response.status);
            return response.json();
        })
        .then(data => {
            console.log('Response data:', data);
            console.log('data.success:', data.success);
            console.log('data.order:', data.order);
            console.log('typeof data.order:', typeof data.order);
            
            if (data.success) {
                console.log('Order successful, hiding modal and adding message');
                hideClientOrderModal();
                
                // Check if order data exists before adding to chat
                if (data.order) {
                    console.log('Calling addOrderMessageToChat with order data');
                    // Add product_name to order object for display
                    const orderWithProduct = {
                        ...data.order,
                        product_name: data.product_name,
                        quantity: data.quantity
                    };
                    console.log('Order with product:', orderWithProduct);
                    addOrderMessageToChat(orderWithProduct);
                } else {
                    console.error('No order data in response, cannot add message to chat');
                }
                
                showNotification('Order request sent successfully!', 'success');
            } else {
                console.log('Order failed:', data.error);
                showNotification(data.error || 'Failed to send order request', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showNotification('Failed to send order request', 'error');
        });
    }

    // Handle client booking form submission
    function submitBookingForm() {
        console.log('submitBookingForm called');
        
        const serviceSelect = document.getElementById('clientBookingService');
        const dateInput = document.getElementById('clientBookingDate');
        const timeInput = document.getElementById('clientBookingTime');
        const notesInput = document.getElementById('clientBookingNotes');
        
        console.log('Form elements:', {
            service: serviceSelect?.value,
            date: dateInput?.value,
            time: timeInput?.value,
            notes: notesInput?.value
        });
        
        // Validate form
        if (!serviceSelect || !serviceSelect.value) {
            console.error('No service selected');
            showNotification('Please select a service', 'error');
            return;
        }
        if (!dateInput || !dateInput.value) {
            console.error('No date selected');
            showNotification('Please select a date', 'error');
            return;
        }
        if (!timeInput || !timeInput.value) {
            console.error('No time selected');
            showNotification('Please select a time', 'error');
            return;
        }
        
        // Combine date and time values in RFC3339 format
        const bookingDateTime = `${dateInput.value}T${timeInput.value}:00Z`;
        console.log('Booking datetime:', bookingDateTime);
        
        const bookingData = {
            service_id: parseInt(serviceSelect.value),
            scheduled_date: bookingDateTime,
            notes: notesInput.value,
            business_id: businessId
        };
        
        console.log('Booking data:', bookingData);

        console.log('Sending booking request to:', '/customer/bookings');
        
        fetch('/customer/bookings', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(bookingData)
        })
        .then(response => {
            console.log('Booking response status:', response.status);
            if (!response.ok) {
                // Get the error response text to see what the actual error is
                return response.text().then(text => {
                    console.log('Error response text:', text);
                    try {
                        const errorData = JSON.parse(text);
                        throw new Error(errorData.error || `HTTP error! status: ${response.status}`);
                    } catch (e) {
                        if (e instanceof SyntaxError) {
                            // If it's not JSON, show the raw text
                            throw new Error(`HTTP error! status: ${response.status} - ${text.substring(0, 100)}`);
                        }
                        throw e;
                    }
                });
            }
            return response.text().then(text => {
                console.log('Raw response text:', text);
                try {
                    return JSON.parse(text);
                } catch (e) {
                    console.error('JSON parse error:', e);
                    console.error('Response was not JSON, received:', text.substring(0, 200));
                    throw new Error('Server returned non-JSON response');
                }
            });
        })
        .then(data => {
            console.log('Response data:', data);
            console.log('data.success:', data.success);
            console.log('data.booking:', data.booking);
            console.log('typeof data.booking:', typeof data.booking);
            
            if (data.success) {
                console.log('Booking successful, hiding modal and adding message');
                hideClientBookingModal();
                
                // Check if booking data exists before adding to chat
                if (data.booking) {
                    console.log('Calling addBookingMessageToChat with booking data');
                    // Add service_name to booking object for display
                    const bookingWithService = {
                        ...data.booking,
                        service_name: data.service_name
                    };
                    console.log('Booking with service:', bookingWithService);
                    addBookingMessageToChat(bookingWithService);
                } else {
                    console.error('No booking data in response, cannot add message to chat');
                }
                
                showNotification('Booking request sent successfully!', 'success');
            } else {
                console.log('Booking failed:', data.error);
                showNotification(data.error || 'Failed to send booking request', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showNotification('Failed to send booking request: ' + error.message, 'error');
        });
    }

    // Auto-scroll to bottom on load
    window.addEventListener('load', function() {
        const messagesContainer = document.getElementById('messages-container');
        if (messagesContainer) {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
        
        // Order and booking data is now rendered directly from template, no parsing needed
        // Fetch orders and add them to chat
        fetchOrdersAndAddToChat();
        
        // Start polling for new messages and orders
        startMessagePolling();
    });

        function fetchOrdersAndAddToChat() {
            fetch(`/customer/businesses/${businessId}/orders`)
                .then(response => response.json())
                .then(orders => {
                    const messagesContainer = document.getElementById('messages-container');
                    if (messagesContainer) {
                        orders.forEach(order => {
                            // Add product_name to order object for display
                            const orderWithProduct = {
                                ...order,
                                product_name: order.product_name || 'Unknown Product'
                            };
                            addOrderMessageToChat(orderWithProduct);
                        });
                    }
                })
                .catch(error => {
                    console.error('Error fetching orders:', error);
                });
        }

    
    function addOrderMessageToChat(order) {
        const messagesContainer = document.getElementById('messages-container');
        
        if (!messagesContainer) {
            return;
        }
        
        // Create message element with [orderid][productname][edit icon] format
        const messageDiv = document.createElement('div');
        messageDiv.className = 'flex justify-end';
        
        const messageHTML = '<div class="max-w-xs lg:max-w-md w-full"><div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-3" data-message-id="' + order.id + '" data-order-content="🛒 ORDER:' + order.id + ' | ' + order.product_name + ' x' + order.quantity + ' ($' + order.total_amount + ') | Status: pending' + (order.notes ? ' | Notes: ' + order.notes : '') + '"><div class="flex items-center justify-between mb-2"><div class="flex items-center space-x-2"><span class="font-semibold text-blue-800 text-sm">[' + order.id + ']</span><span class="text-gray-700 text-sm">' + order.product_name + '</span></div><button onclick="editOrderMessage(' + order.id + ')" class="text-blue-600 hover:text-blue-800 text-xs" title="Edit Order"><i class="fas fa-edit"></i></button></div><div class="order-details text-sm text-gray-700"><p class="text-sm hidden">🛒 ORDER:' + order.id + ' | ' + order.product_name + ' x' + order.quantity + ' ($' + order.total_amount + ') | Status: pending' + (order.notes ? ' | Notes: ' + order.notes : '') + '</p></div><div class="flex items-center justify-between mt-2"><p class="text-xs text-gray-500">' + new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) + '</p><span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded">Pending</span></div></div></div></div>';
        
        messageDiv.innerHTML = messageHTML;
        messagesContainer.appendChild(messageDiv);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function addBookingMessageToChat(booking) {
        const messagesContainer = document.getElementById('messages-container');
        
        // Create structured message content like backend
        const bookingDate = new Date(booking.scheduled_date);
        const bookingContent = `📅 BOOKING:${booking.id} | ${booking.service_name} | ${bookingDate.toLocaleDateString()} ${bookingDate.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})} | Status: pending${booking.notes ? ` | Notes: ${booking.notes}` : ''}`;
        
        const bookingMessage = `
            <div class="flex justify-end">
                <div class="max-w-xs lg:max-w-md w-full">
                    <div class="bg-purple-50 border border-purple-200 rounded-lg px-4 py-3" data-message-id="${booking.id}" data-booking-content="${bookingContent}">
                        <div class="flex items-center justify-between mb-2">
                            <div class="flex items-center space-x-2">
                                <i class="fas fa-calendar text-purple-600"></i>
                                <span class="font-semibold text-purple-800 text-sm">Booking</span>
                            </div>
                            <button onclick="editBookingMessage(${booking.id})" class="text-purple-600 hover:text-purple-800 text-xs" title="Edit Booking">
                                <i class="fas fa-edit"></i>
                            </button>
                        </div>
                        <div class="booking-details text-sm text-gray-700">
                            <p class="text-sm">${bookingContent}</p>
                        </div>
                        <div class="flex items-center justify-between mt-2">
                            <p class="text-xs text-gray-500">Just now</p>
                            <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded">Pending</span>
                        </div>
                    </div>
                </div>
            </div>
        `;
        messagesContainer.insertAdjacentHTML('beforeend', bookingMessage);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.className = `fixed top-4 right-4 p-4 rounded-lg shadow-lg z-50 ${
            type === 'success' ? 'bg-green-500 text-white' :
            type === 'error' ? 'bg-red-500 text-white' :
            type === 'warning' ? 'bg-yellow-500 text-white' :
            'bg-blue-500 text-white'
        }`;
        notification.textContent = message;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.remove();
        }, 3000);
    }

    // Edit order/booking message functions
    function editOrderMessage(messageId) {
        const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
        if (!messageEl) return;
        
        const currentContent = messageEl.getAttribute('data-order-content') || messageEl.querySelector('.order-details p')?.textContent || '';
        
        // Extract current values from structured message
        // Format: 🛒 ORDER:order_id | product_name xquantity ($total) | Status: status | Notes: notes
        const parts = currentContent.split('|').map(p => p.trim());
        let notes = '';
        const notesPart = parts.find(p => p.startsWith('Notes:'));
        if (notesPart) {
            notes = notesPart.replace('Notes:', '').trim();
        }
        
        const newNotes = prompt('Update order notes:', notes);
        if (newNotes === null) return; // Cancelled
        
        // Reconstruct message with updated notes
        let newContent = parts.filter(p => !p.startsWith('Notes:')).join(' | ');
        if (newNotes.trim()) {
            newContent += ` | Notes: ${newNotes.trim()}`;
        }
        
        updateMessageContent(messageId, newContent);
    }

    function editBookingMessage(messageId) {
        const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
        if (!messageEl) return;
        
        const currentContent = messageEl.getAttribute('data-booking-content') || messageEl.querySelector('.booking-details p')?.textContent || '';
        
        // Extract current values
        // Format: 📅 BOOKING:booking_id | service_name | date | Status: status | Notes: notes
        const parts = currentContent.split('|').map(p => p.trim());
        let notes = '';
        const notesPart = parts.find(p => p.startsWith('Notes:'));
        if (notesPart) {
            notes = notesPart.replace('Notes:', '').trim();
        }
        
        const newNotes = prompt('Update booking notes:', notes);
        if (newNotes === null) return; // Cancelled
        
        // Reconstruct message with updated notes
        let newContent = parts.filter(p => !p.startsWith('Notes:')).join(' | ');
        if (newNotes.trim()) {
            newContent += ` | Notes: ${newNotes.trim()}`;
        }
        
        updateMessageContent(messageId, newContent);
    }

    function updateMessageContent(messageId, newContent) {
        fetch(`/messages/${messageId}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + getCookie('customer_token')
            },
            body: JSON.stringify({ content: newContent })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showNotification('Updated successfully!', 'success');
                // Reload chat to show updated message
                if (businessId) {
                    loadBusiness(businessId);
                }
            } else {
                showNotification(data.error || 'Failed to update', 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showNotification('Failed to update', 'error');
        });
    }

    function cancelOrder(orderId) {
        if (confirm('Are you sure you want to cancel this order?')) {
            fetch(`/customer/orders/${orderId}/cancel`, {
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + getCookie('customer_token')
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('Order cancelled successfully', 'success');
                    // Reload chat to update
                    if (businessId) {
                        loadBusiness(businessId);
                    }
                } else {
                    showNotification(data.error || 'Failed to cancel order', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showNotification('Failed to cancel order', 'error');
            });
        }
    }

    function cancelBooking(bookingId) {
        if (confirm('Are you sure you want to cancel this booking?')) {
            fetch(`/customer/bookings/${bookingId}/cancel`, {
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + getCookie('customer_token')
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('Booking cancelled successfully', 'success');
                    // Reload chat to update
                    if (businessId) {
                        loadBusiness(businessId);
                    }
                } else {
                    showNotification(data.error || 'Failed to cancel booking', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showNotification('Failed to cancel booking', 'error');
            });
        }
    }
</script>

</div>
<!-- End Main Chat Container -->

<!-- Client Order Modal -->
<div id="clientOrderModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3">
            <h3 class="text-lg font-medium text-gray-900">Place Order</h3>
            <form id="clientOrderForm" class="mt-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700">Select Product</label>
                    <select id="clientOrderProduct" required class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Choose a product...</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Quantity</label>
                    <input type="number" id="clientOrderQuantity" min="1" value="1" required class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Delivery Address</label>
                    <textarea id="clientOrderAddress" rows="2" placeholder="Enter delivery address..." class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-blue-500 focus:border-blue-500"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Notes</label>
                    <textarea id="clientOrderNotes" rows="2" placeholder="Any special requests..." class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-blue-500 focus:border-blue-500"></textarea>
                </div>
                <div class="flex justify-end space-x-3 pt-4">
                    <button type="button" onclick="hideClientOrderModal()" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-4 py-2 rounded">
                        Cancel
                    </button>
                    <button type="button" onclick="console.log('Button clicked!'); submitOrderForm()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">
                        Send Order Request
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Client Booking Modal -->
<div id="clientBookingModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3">
            <h3 class="text-lg font-medium text-gray-900">Request Booking</h3>
            <form id="clientBookingForm" class="mt-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700">Select Service</label>
                    <select id="clientBookingService" required class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-purple-500 focus:border-purple-500">
                        <option value="">Choose a service...</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Date</label>
                    <input type="date" id="clientBookingDate" required class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-purple-500 focus:border-purple-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Time</label>
                    <input type="time" id="clientBookingTime" required class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-purple-500 focus:border-purple-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Notes</label>
                    <textarea id="clientBookingNotes" rows="2" placeholder="Any special requests..." class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-purple-500 focus:border-purple-500"></textarea>
                </div>
                <div class="flex justify-end space-x-3 pt-4">
                    <button type="button" onclick="hideClientBookingModal()" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-4 py-2 rounded">
                        Cancel
                    </button>
                    <button type="button" onclick="submitBookingForm()" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded">
                        Send Booking Request
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
